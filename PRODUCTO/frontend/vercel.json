{
  "rewrites": [
    {
      "source": "/auth/:path*",
      "destination": "https://api-gateway-production-0014.up.railway.app/auth/:path*"
    },
    {
      "source": "/usuarios/:path*",
      "destination": "https://api-gateway-production-0014.up.railway.app/usuarios/:path*"
    },
    {
      "source": "/territorios/:path*",
      "destination": "https://api-gateway-production-0014.up.railway.app/territorios/:path*"
    },
    {
      "source": "/documentos/:path*",
      "destination": "https://api-gateway-production-0014.up.railway.app/documentos/:path*"
    },
    {
      "source": "/api/blockchain/:path*",
      "destination": "https://api-gateway-production-0014.up.railway.app/api/blockchain/:path*"
    },
    {
      "source": "/api/validacion/:path*",
      "destination": "https://api-gateway-production-0014.up.railway.app/api/validacion/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
